<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        These entitlements require explicit approval from Apple. Request them
        at https://developer.apple.com/contact/request/system-extension/ —
        a free / standard developer account cannot self-assign them.

        Until Apple grants the HID transport entitlement, the dext can only be
        loaded in development with SIP modified + `systemextensionsctl developer on`.
    -->

    <!-- Core DriverKit entitlement (allows the process to be a driver). -->
    <key>com.apple.developer.driverkit</key>
    <true/>

    <!-- Allows matching/communicating over the HID transport. -->
    <key>com.apple.developer.driverkit.transport.hid</key>
    <true/>

    <!-- Allows providing an IOHIDFamily event service. -->
    <key>com.apple.developer.driverkit.family.hid.eventservice</key>
    <true/>

    <!-- Needed to send the Device Mode feature report (setReport). -->
    <key>com.apple.developer.driverkit.allow-any-userclient-access</key>
    <true/>
</dict>
</plist>
